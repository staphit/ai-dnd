# Required for the OpenAI Dungeon Master Agent.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-terra
OPENAI_IMAGE_MODEL=gpt-image-2

# Tracing is off by default to avoid recording campaign content.
# Set to 1 if you intentionally want traces in the OpenAI dashboard.
OPENAI_AGENT_TRACING=0

# Local web server port.
PORT=4318
