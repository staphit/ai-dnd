# Copy to backend/.env (or repo-root .env) and adjust. All values are optional.

# ---- DM data source ----
#   codex (default) — local Codex CLI (ChatGPT login)
#   grok            — Grok Build CLI (`grok login`, SuperGrok/X Premium，不必 API key)
#                     若 CLI 未登入且有 XAI_API_KEY，則改走 HTTP API
DM_PROVIDER=codex

# ---- Grok (when DM_PROVIDER=grok) ----
# Preferred: install CLI and sign in (no API key):
#   curl -fsSL https://x.ai/cli/install.sh | bash
#   grok login
# GROK_MODE=auto          # auto | cli | api  (auto: 先 CLI 登入，否則 API key)
# GROK_CLI_PATH=          # optional path to grok.exe
# GROK_MODEL=grok-4.5   # only grok-4.5 is used; other values are ignored
#
# Optional HTTP API (required for IMAGE_BACKEND=grok image generation):
# Get a key at https://console.x.ai/
# XAI_API_KEY=
# GROK_API_KEY=          # alias for XAI_API_KEY
# XAI_BASE_URL=https://api.x.ai/v1
# GROK_IMAGE_MODEL=grok-imagine-image-quality

# ---- Codex CLI (when DM_PROVIDER=codex) ----
CODEX_CLI_PATH=codex
CODEX_MODEL=
# Default reasoning effort for DM turns (minimal|low|medium|high|xhigh).
# Empty keeps the CLI default; the frontend can override per campaign.
CODEX_EFFORT=

# How DM turns reach Codex:
#   app-server (default) keep one `codex app-server` process alive. It follows a
#              "one story = one connection" model: the connection binds to the
#              current story's thread and only (re)connects on explicit player
#              consent (the "連線 codex" button; no silent auto-restart). Turns
#              send only the delta and Codex reads prior context from a memory
#              file. Image generation still uses exec.
#   exec       spawn `codex exec` per request (fallback; full-context, no memory).
# Note: CODEX_MODEL must be a model your Codex CLI supports.
CODEX_MODE=app-server

# Story memory (app-server mode only). Raw turns are stored in SQLite and a
# compacted Markdown file is written under CODEX_CWD/campaign-data/memory/<id>.md
# for Codex to read. Compaction (a background `codex exec` summary) runs once the
# uncompacted event count reaches the threshold.
# MEMORY_COMPACT_THRESHOLD=20
# MEMORY_TAIL=40

# Image generation backend used when the frontend does not pick one:
#   codex — Codex CLI's built-in image_gen tool (cloud, needs codex login)
#   grok  — xAI Grok Imagine (needs XAI_API_KEY); default when DM_PROVIDER=grok
#   local — Stable Diffusion WebUI Forge on this machine (needs --api flag)
IMAGE_BACKEND=codex

# Local SD Forge settings (only used by the "local" backend).
# Install once with scripts/forge-setup.sh (clones into vendor/, can download a
# checkpoint), then start with scripts/forge.sh. Windows: webui-user.bat with
# set COMMANDLINE_ARGS=--api
FORGE_URL=http://127.0.0.1:7860
# Checkpoint file name as listed in Forge's model dropdown, e.g.
# juggernautXL_v9.safetensors. Empty uses the currently loaded checkpoint.
FORGE_CHECKPOINT=
# Preset picks sampler defaults and resolution:
#   quality   — standard SDXL checkpoints (30 steps, CFG 5, DPM++ 2M Karras, 1216x832/1024x1024)
#   turbo     — SD-Turbo, low VRAM (1 step, CFG 2, Euler a, 768x512/512x512)
#   hyper     — SD1.5 photoreal (epiCRealism) + Hyper-SD 8-step LoRA (8 steps, CFG 2 to keep negatives active, DDIM SGM-Uniform/trailing, 768x512·512x512), lowest VRAM
FORGE_PRESET=quality
# Optional LoRA tags prepended to every prompt (chain several with commas).
# The hyper preset needs Hyper-SD; add_detail sharpens detail. Files go in
# models/Lora/.
# FORGE_LORA=<lora:Hyper-SD15-8steps-lora:1>, <lora:add_detail:0.6>
# ADetailer face-fix model (re-inpaints faces; needs the adetailer extension
# in Forge). Empty = off.
# FORGE_ADETAILER=face_yolov8n.pt
# Individual overrides (win over the preset).
# FORGE_STEPS=30
# FORGE_CFG=5
# FORGE_SAMPLER=DPM++ 2M
# FORGE_SCHEDULER=Karras
# FORGE_SCENE_WIDTH=1216
# FORGE_SCENE_HEIGHT=832

# Optional second local checkpoint, selectable as backend id "local2"
# alongside "local" above (same Forge server, swapped per request).
# FORGE_CHECKPOINT_2=
# FORGE_PRESET_2=turbo
# FORGE_CFG_2=2

# Log every DM and image prompt to the server console (1/true to enable).
# LOG_PROMPTS=0
# Also tee server logs to dated files (default logs/server-YYYY-MM-DD.log; empty = off).
# LOG_FILE=logs/server.log

# HTTP port (backend serves API + built frontend + images)
PORT=4318

# Path overrides — defaults resolve relative to the repo root (the .git parent).
# WEB_DIST=../web-dist
# DND_DATA_DIR=../campaign-data
# CODEX_CWD=..
